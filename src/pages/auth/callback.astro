---
// src/pages/auth/callback.astro
// This page is reached after a successful OAuth flow.
// If it's opened in a popup, it signals the parent window and closes itself.
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Authenticating...</title>
</head>
<body>
    <script>
        if (window.opener) {
            // Signal the parent window that authentication is complete
            window.opener.postMessage("better-auth-callback-success", window.location.origin);
            // Close this window
            window.close();
        } else {
            // If not in a popup, just go home
            window.location.href = "/";
        }
    </script>
</body>
</html>
