---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const allBlogPosts = await getCollection('blog')
const sortedBlogPosts = allBlogPosts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
)
const latestPosts = sortedBlogPosts.slice(0, 4)
---

<Layout title='Encelerate: Enhance and Accelerate'>
    <main
        class='relative z-10 flex flex-col items-center justify-center min-h-screen text-center p-4'
    >
        <div class='mb-12'>
            <h1 class='text-4xl lg:text-6xl text-gray-900 dark:text-white mb-6'>
                encelerate.com
            </h1>
            <h3
                class='text-lg md:text-3xl lg:text-4xl text-gray-700 dark:text-gray-300'
            >
                I'm here to
            </h3>
            <h2
                class='text-2xl md:text-3xl lg:text-4xl text-gray-900 dark:text-white'
            >
                <b>en</b>hance and ac<b>celerate</b>
            </h2>
        </div>
        <div
            class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto'
        >
            {
                latestPosts.map(post => (
                    <a
                        href={`/blog/${post.id}`}
                        class='block bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 hover:shadow-xl transition-shadow duration-300'
                    >
                        <h3 class='text-xl font-semibold text-gray-900 dark:text-white'>
                            {post.data.title}
                        </h3>
                        <p class='text-gray-600 dark:text-gray-400 mt-2'>
                            {post.data.description}
                        </p>
                    </a>
                ))
            }
        </div>
        <div class='mt-8'>
            <a
                href='/blog'
                class='text-blue-600 dark:text-blue-400 hover:underline text-lg'
                >More articles &rarr;</a
            >
        </div>
    </main>
</Layout>
