---
import Layout from '../layouts/Layout.astro';
import { ossRepoList, getLanguageLogo } from '../data/oss/ossRepoList';

export const prerender = true;

// Fetch GitHub token from environment (build time) or Cloudflare binding (if hybrid, though this page is static)
let githubToken: string | undefined;
try {
  // This import will only succeed in a Cloudflare Workers environment
  const workers = await import('cloudflare:workers');
  githubToken = (workers.env as any).githubPublicRepoReadOnlyAccessBenedictJohannes;
} catch (e) {
  // This will be used during build time (Node.js)
  githubToken = process.env.githubPublicRepoReadOnlyAccessBenedictJohannes;
}

async function getLatestCommit(repoUrl: string) {
  const repoPath = repoUrl.replace('https://github.com/', '');
  const url = `https://api.github.com/repos/${repoPath}/commits?per_page=1`;
  
  const headers: HeadersInit = {
    'Accept': 'application/vnd.github.v3+json',
    'User-Agent': 'Encelerate-OSS-Fetcher'
  };
  
  if (githubToken) {
    headers['Authorization'] = `Bearer ${githubToken}`;
  }

  try {
    const response = await fetch(url, { headers });
    if (!response.ok) {
      throw new Error(`GitHub API error: ${response.status} ${response.statusText}`);
    }
    const data = await response.json() as any[];
    return data[0]?.commit?.committer?.date || null;
  } catch (error) {
    console.error(`Error fetching commit for ${repoPath}:`, error);
    return null;
  }
}

// Enrichment Pipeline
const enrichedProjects = await Promise.all(
  ossRepoList.map(async (project) => {
    const lastCommit = await getLatestCommit(project.repo);
    return { ...project, lastCommit };
  })
);

// Sort by last commit date (descending)
enrichedProjects.sort((a, b) => {
  const dateA = a.lastCommit ? new Date(a.lastCommit).getTime() : 0;
  const dateB = b.lastCommit ? new Date(b.lastCommit).getTime() : 0;
  return dateB - dateA;
});

const title = "Open Source Software";
const description = "A collection of open source tools and projects I've built and maintained.";
---

<Layout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-6 py-12">
    <header class="mb-16 animate-fade-in">
      <h1 class="text-4xl font-extrabold mb-4">
        Open Source
      </h1>
      <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
        Here are some of my projects built in public, sorted by recent activity.
      </p>
    </header>

    <div class="grid gap-8">
      {enrichedProjects.map((project, index) => (
        <div 
          class="group relative block p-8 rounded-2xl border border-zinc-800 bg-zinc-900/50 hover:bg-zinc-800/55 transition-all duration-300 ease-in-out hover:shadow-[0_0_40px_rgba(59,130,246,0.1)] overflow-hidden"
          style={`animation-delay: ${index * 100}ms`}
        >
          <div class="absolute inset-0 bg-linear-to-br from-blue-500/5 to-emerald-500/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
          
          <div class="relative z-10">
            <div class="flex flex-wrap items-start">
              <div class="flex-1">
                <h2 class="text-2xl font-extrabold group-hover:text-amber-400 group-hover:translate-x-1 transition-all duration-300 ease-in-out">
                  {project.name}
                </h2>
                
                <div class="flex flex-wrap items-center gap-3 mt-2 mb-4">
                  <!-- Repository Shield -->
                  <a 
                    href={project.repo} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="transition-transform duration-300 hover:scale-110"
                  >
                    {(() => {
                      const repoShortText = project.repoShortText || 'GitHub';
                      const lower = repoShortText.toLowerCase();
                      const logo = lower.includes('github') ? 'github' : 
                                   lower.includes('gitlab') ? 'gitlab' : 
                                   lower.includes('bitbucket') ? 'bitbucket' : 'git';
                      return (
                        <img 
                          src={`https://img.shields.io/badge/Repository-${repoShortText}-333?logo=${logo}&logoColor=white`} 
                          alt={`${repoShortText} Repository`} 
                          class="h-5 rounded opacity-80 group-hover:opacity-100 transition-opacity duration-300" 
                        />
                      );
                    })()}
                  </a>

                  <!-- Language -->
                  <img src={getLanguageLogo(project.language)} alt={project.language} class="h-5 rounded transition-all duration-300 hover:scale-110 opacity-80 group-hover:opacity-100" />
                  
                  <!-- Other Shields -->
                  {project.shields && project.shields.map(shield => (
                    shield.url ? (
                      <a 
                        href={shield.url} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="transition-transform duration-300 hover:scale-110"
                      >
                        <img src={shield.img} alt={shield.label} class="h-5 rounded opacity-80 group-hover:opacity-100 transition-opacity duration-300" />
                      </a>
                    ) : (
                      <img src={shield.img} alt={shield.label} class="h-5 rounded transition-all duration-300 hover:scale-110 opacity-80 group-hover:opacity-100" />
                    )
                  ))}

                  <!-- Updated Date -->
                  {project.lastCommit && (
                     <span class="text-xs text-zinc-500 font-medium bg-zinc-800/50 px-2 py-0.5 rounded-full border border-zinc-700/50 whitespace-nowrap transition-all duration-300 group-hover:border-zinc-600/50 group-hover:text-zinc-400 group-hover:translate-x-1">
                      Updated: {new Date(project.lastCommit).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'short', 
                        day: 'numeric' 
                      })}
                    </span>
                  )}
                </div>
              </div>
            </div>
            <p 
              class="text-zinc-400 leading-relaxed group-hover:text-zinc-300 group-hover:translate-x-0.5 transition-all duration-300" 
              set:html={project.description.replace(/\*\*(.*?)\*\*/g, '<strong class="text-zinc-200 font-semibold">$1</strong>')}
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Entrance animation for the grid items */
  .grid > div {
    opacity: 0;
    animation: fadeIn 0.8s ease-out forwards;
  }
</style>
