---
export const prerender = true;
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const allBlogPosts = await getCollection('blog', ({ data }) => {
	return data.private !== true;
})
const sortedBlogPosts = allBlogPosts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
)
---

<Layout title='All Articles - Encelerate'>
    <main class='max-w-4xl mx-auto py-8 px-4'>
        <h1
            class='text-4xl font-bold text-gray-900 dark:text-white mb-8 text-center'
        >
            All Articles
        </h1>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
            {
                sortedBlogPosts.map(post => (
                    <a
                        href={`/blog/${post.id}`}
                        class='block bg-white dark:bg-neutral-800 rounded-lg shadow-lg p-6 hover:shadow-xl transition-shadow duration-300'
                    >
                        <h2 class='text-2xl font-semibold text-gray-900 dark:text-white'>
                            {post.data.title}
                        </h2>
                        <p class='text-gray-600 dark:text-gray-400 mt-2'>
                            {post.data.description}
                        </p>
                        <p class='text-sm text-gray-500 dark:text-gray-400 mt-4'>
                            {post.data.pubDate.toLocaleDateString('en-US', {
                                year: 'numeric',
                                month: 'long',
                                day: 'numeric',
                            })}
                        </p>
                    </a>
                ))
            }
        </div>
        <div class='mt-8 text-center'>
            <a
                href='/'
                class='text-amber-600 dark:text-amber-400 hover:underline text-lg'
                >&larr; Back to Home</a
            >
        </div>
    </main>
</Layout>

<style is:global>
    @reference '../styles/global.css';
    body {
        @apply bg-gray-100 dark:bg-neutral-900 transition-colors duration-500;
    }
</style>
