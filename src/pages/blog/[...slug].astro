---
import { type CollectionEntry, getCollection, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'

export async function getStaticPaths() {
    const posts = await getCollection('blog')
    return posts.map(post => ({
        params: { slug: post.id },
        props: post,
    }))
}
type Props = CollectionEntry<'blog'>

const post = Astro.props
const { Content } = await render(post)
---

<Layout title={post.data.title}>
    <main class='max-w-4xl mx-auto py-8 px-4'>
        <a
            href='/blog'
            class='text-blue-600 dark:text-blue-400 hover:underline text-lg mb-4 block'
            >&larr; Back to Articles</a
        >
        <h1 class='text-5xl font-bold text-gray-900 dark:text-white mb-4'>
            {post.data.title}
        </h1>
        <p class='text-2xl text-gray-700 dark:text-gray-300 mb-6'>
            {post.data.description}
        </p>
        <p class='text-gray-500 dark:text-gray-400 mb-8'>
            Published on {
                post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                })
            }
        </p>
        <article class='prose dark:prose-invert max-w-none'>
            <Content />
        </article>
    </main>
</Layout>

<style is:global>
    @reference '../../styles/global.css';
    .prose {
        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            @apply text-gray-900 dark:text-white;
        }
        h1 {
            @apply text-4xl mt-4 mb-3 font-bold;
        }
        h2 {
            @apply text-2xl mt-3 mb-2 font-bold;
        }
        h3 {
            @apply text-xl mt-3 mb-2 font-bold;
        }
        h4 {
            @apply text-lg mt-2 mb-2 font-bold;
        }
        h5,
        h6 {
            @apply mt-2 mb-2 font-bold;
        }
        p,
        ul,
        ol {
            @apply mb-2 text-justify;
        }
        ul ul,
        ol ol,
        ul ol,
        ol ul {
            @apply ml-4;
        }
        p,
        ul,
        ol {
            @apply text-gray-800 dark:text-gray-200;
        }
        li {
            @apply list-disc list-inside;
        }
        ol {
            @apply list-decimal;
        }
        a {
            @apply text-blue-600 dark:text-blue-400 hover:underline;
        }
    }
</style>
