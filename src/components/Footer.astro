---
const today = new Date();
---

<footer class="py-6 px-4 bg-white dark:bg-neutral-900 border-t border-neutral-200/50 dark:border-neutral-800/50">
	<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
		<div class="text-neutral-500 dark:text-neutral-400 text-sm">
			&copy; {today.getFullYear()} encelerate.com. All rights reserved.
		</div>
		<nav class="flex gap-6 text-sm font-medium text-neutral-600 dark:text-neutral-300">
			<a href="/privacy-policy" class="hover:text-amber-600 dark:hover:text-amber-400 transition-colors">Privacy Policy</a>
			<a href="/terms-of-service" class="hover:text-amber-600 dark:hover:text-amber-400 transition-colors">Terms of Service</a>
			<a href="/rss.xml" class="group flex items-center gap-1 hover:text-amber-600 dark:hover:text-amber-400 transition-colors" title="RSS Feed">
				<span class="text-orange-600 dark:text-orange-500 group-hover:text-orange-600 dark:group-hover:text-orange-500 transition-colors">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M4 11a9 9 0 0 1 9 9"></path>
						<path d="M4 4a16 16 0 0 1 16 16"></path>
						<circle cx="5" cy="19" r="1"></circle>
					</svg>
				</span>
				RSS
			</a>
		</nav>
	</div>
</footer>

