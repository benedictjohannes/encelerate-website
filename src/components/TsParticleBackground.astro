<div id='tsparticles' class='absolute inset-0 z-[-1]'></div>

<script>
    async function loadParticles() {
        const { tsParticles } = await import('@tsparticles/engine')
        const { loadLinksPreset } = await import('@tsparticles/preset-links')
        
        const darkMediaQuery = window.matchMedia('(prefers-color-scheme: dark)')
        
        // Configuration Logic
        const setOptions = (isDark: boolean) => {
            tsParticles.load({
                id: 'tsparticles',
                options: {
                    preset: 'links',
                    // Keep background transparent so CSS handles the color
                    background: { color: { value: 'transparent' } },
                    particles: {
                        links: {
                            color: { value: isDark ? '#232323' : '#cacaca' },
                        },
                        color: {
                            value: isDark ? '#343434' : '#bababa',
                        },
                    },
                },
            })
        }

        // Initialize
        await loadLinksPreset(tsParticles)
        setOptions(darkMediaQuery.matches)

        // Listener for theme changes
        darkMediaQuery.addEventListener('change', e => setOptions(e.matches))
    }

    // Check if it's a crawler to avoid unnecessary resource usage
    const isCrawler = /bot|spider|google|headless/i.test(navigator.userAgent);

    // Use a helper to ensure it only runs once and after assets are loaded
    const init = () => {
        if (isCrawler || document.querySelector('#tsparticles canvas')) return;
        loadParticles();
    };

    // Check if the page is already loaded, otherwise wait for the 'load' event
    if (document.readyState === 'complete') {
        init();
    } else {
        window.addEventListener('load', init, { once: true });
    }
</script>
