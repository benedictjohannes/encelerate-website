---
import '../styles/global.css'
import TsParticleBackground from '../components/TsParticleBackground.astro'
import { SITE_TITLE } from '../consts'

interface Props {
    title: string
    description?: string
    pageType?: 'website' | 'article'
    particles?: boolean
}

const { title, description, pageType, particles = true } = Astro.props
---

<!doctype html>
<html lang='en'>
    <head>
        <meta charset='UTF-8' />
        <meta name='viewport' content='width=device-width' />
        <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
        <meta name='generator' content={Astro.generator} />
        <title>{title ? `${title} - ${SITE_TITLE}` : SITE_TITLE}</title>
        <meta property='og:site_name' content={SITE_TITLE} />
        <meta property='og:title' content={title} />
        {description && <meta name='description' content={description} />}
        {
            description && (
                <meta property='og:description' content={description} />
            )
        }
        {pageType && <meta property='og:type' content={pageType} />}
    </head>
    <body>
        {particles && <TsParticleBackground />}
        <slot />
    </body>
</html>
